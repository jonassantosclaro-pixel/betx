rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isUserRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData(request.auth.uid).role == role;
    }

    // Lazy short-circuit evaluations for admin emails to prevent database rule crashes on first logins
    function isAdmin() {
      return (isSignedIn() && (
        request.auth.token.email == 'phbet@x.com' || 
        request.auth.token.email == 'jonassantosclaro@gmail.com' ||
        request.auth.token.email == 'admin@phbet.com'
      )) || isUserRole('admin');
    }

    function isCambista() {
      return isUserRole('cambista');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Server bypass validation helpers using secure private signatures in document data context
    function isIncomingServerBypass() {
      return request.resource != null && 
             request.resource.data != null && 
             request.resource.data.keys().hasAll(['serverSecret']) && 
             request.resource.data.serverSecret == "PH_BET_SECURE_SERVER_COMPUTE_KEY_2026_BYPASS";
    }

    function isExistingServerBypass() {
      return resource != null && 
             resource.data != null && 
             resource.data.keys().hasAll(['serverSecret']) && 
             resource.data.serverSecret == "PH_BET_SECURE_SERVER_COMPUTE_KEY_2026_BYPASS";
    }

    function isServerBypass() {
      return isIncomingServerBypass() || isExistingServerBypass();
    }

    // 1. User Rules
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if (isSignedIn() && request.auth.uid == userId && 
        request.resource.data.userId == userId && 
        request.resource.data.status == 'active' && 
        request.resource.data.balance is number && 
        request.resource.data.balance >= 0 &&
        (
          (request.auth.token.email == 'phbet@x.com' || request.auth.token.email == 'jonassantosclaro@gmail.com' || request.auth.token.email == 'admin@phbet.com' ? 
            request.resource.data.role == 'admin' : request.resource.data.role == 'usuario')
        )) || isServerBypass();

      allow update: if (isSignedIn() && (
        // Admin can modify everything
        isAdmin() || 
        // User can only update their own non-sensitive fields or update balance when placing standard bets (usually balance change is decremented by stake)
        (request.auth.uid == userId && 
         request.resource.data.userId == resource.data.userId &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.status == resource.data.status &&
         request.resource.data.balance is number &&
         request.resource.data.balance >= 0)
      )) || isServerBypass();
      
      allow delete: if isAdmin() || isServerBypass();
    }

    // 2. Bets Rules
    match /bets/{betId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.cambistaId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
        isValidId(betId) &&
        request.resource.data.betId == betId &&
        request.resource.data.userId is string &&
        request.resource.data.selections is list &&
        request.resource.data.selections.size() > 0 &&
        request.resource.data.selections.size() <= 8 &&
        request.resource.data.stake is number &&
        request.resource.data.stake > 0 &&
        request.resource.data.odds is number &&
        request.resource.data.potentialPayout is number &&
        request.resource.data.status == 'pending' &&
        (
          // Placed by a cambista
          (isCambista() && request.resource.data.cambistaId == request.auth.uid) ||
          // Placed by standard user themselves
          (request.resource.data.userId == request.auth.uid) ||
          isAdmin()
        );

      allow update: if isAdmin(); // Only admins can resolve (won/lost) or cancel bets
      allow delete: if isAdmin();
    }

    // 3. Games Rules (Legacy Support)
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin() || isServerBypass();
    }

    // 4. Cambistas Rules
    match /cambistas/{cambistaId} {
      allow read: if isSignedIn() && (request.auth.uid == cambistaId || isAdmin());
      allow write: if isAdmin() || isServerBypass(); // Only admins register and manage cambistas accounts
    }

    // 5. System Settings Rules
    match /settings/{settingsId} {
      allow read: if (settingsId == 'global') || isAdmin();
      allow write: if isAdmin() || isServerBypass();
    }

    // 6. Realtime Matches
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin() || isServerBypass();
    }

    // 7. Live Matches
    match /live_matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin() || isServerBypass();
    }

    // 8. Standings
    match /standings/{standingId} {
      allow read: if true;
      allow write: if isAdmin() || isServerBypass();
    }

    // 9. Team Profiles
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin() || isServerBypass();
    }

    // 10. Leagues Info
    match /leagues/{leagueId} {
      allow read, create: if true;
      allow update, delete: if isAdmin() || isServerBypass();
    }

    // 11. Custom Odds Core
    match /odds/{oddsId} {
      allow read: if true;
      allow write: if isAdmin() || isServerBypass();
    }

    // 12. Cache Timestamps / Control
    match /cache_control/{cacheId} {
      allow read: if true;
      allow write: if isAdmin() || isServerBypass();
    }
  }
}
